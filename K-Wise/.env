# =============================================
# K-Wise Frontend Environment Configuration
# VM Production Environment
# Date: December 10, 2025
# =============================================

# Server Configuration
HOST=0.0.0.0
PORT=3000

# Backend API Configuration
REACT_APP_BACKEND_PORT=5000
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_SERVER_URL=http://localhost:5000

# Local Development URLs (fallback)
REACT_APP_LOCAL_API_URL=http://localhost:5000/api
REACT_APP_LOCAL_SERVER_URL=http://localhost:5000

# Environment
REACT_APP_ENV=production

# Feature Flags
REACT_APP_ENABLE_AI=true
REACT_APP_ENABLE_WEBSOCKET=true

# =============================================
# NETWORK ACCESS (ZeroTier) - OPTIONAL
# =============================================
# Uncomment and update with your ZeroTier IP when setting up remote access
# REACT_APP_ZEROTIER_IP=10.147.17.X
# REACT_APP_API_URL=http://10.147.17.X:5000/api
# REACT_APP_SERVER_URL=http://10.147.17.X:5000
