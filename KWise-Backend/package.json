{
  "name": "kwise-backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "test": "jest --runInBand",
    "test:compatibility": "jest --runInBand --coverage=false deterministicCompatibilityService.test.js compatibilitySpecService.test.js offlineAiDisabled.test.js",
    "test:watch": "jest --watchAll",
    "start": "node --no-compilation-cache server.js",
    "dev": "nodemon --exec \"node --no-compilation-cache\" server.js",
    "dev:no-ollama": "nodemon --exec \"node --no-compilation-cache\" server.js",
    "audit:compatibility": "node scripts/audit-offline-compatibility.js",
    "audit:compatibility:strict": "node scripts/audit-offline-compatibility.js --strict",
    "audit:compatibility-data": "node scripts/audit-compatibility-data.js",
    "audit:kiosk-images": "node scripts/kiosk-image-data-audit.js",
    "generate:kiosk-image-variants": "node scripts/generate-kiosk-image-variants.js",
    "normalize:compatibility-specs": "node scripts/canonicalize-product-specs.js",
    "audit:cleanup": "node scripts/generate-cleanup-manifest.js",
    "stress:compatibility": "node scripts/brutal-compatibility-stress.js",
    "stress:db": "node scripts/brutal-db-stress.js",
    "stress:security": "node scripts/brutal-security-stress.js",
    "stress:kiosk": "node scripts/brutal-kiosk-route-stress.js",
    "stress:live-stack": "node scripts/brutal-live-stack-stress.js --mode=production",
    "stress:all": "npm run audit:compatibility:strict && npm run audit:cleanup && npm run test:compatibility && npm run stress:compatibility && npm run stress:db && npm run stress:security",
    "stress:all:live": "npm run stress:all && npm run stress:live-stack"
  },
