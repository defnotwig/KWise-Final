const express = require('express');
const router = express.Router();
const { protect, restrictTo } = require('../middleware/auth');
const imageUploadController = require('../controllers/imageUploadController');

/**
 * Enhanced Image Upload Routes for K-Wise Stock Management
 * Handles secure image uploads with per-category folder structure
 */

// POST /api/images/stock - Upload image for stock item
router.post('/stock', 
    protect, 
    restrictTo('admin', 'superadmin'), 
    imageUploadController.single,
    imageUploadController.uploadStockImage
);

// GET /api/images/stock/:id - Get image info for product
router.get('/stock/:id', 
    protect, 
    restrictTo('admin', 'superadmin', 'developer'),
    imageUploadController.getImageInfo
);
