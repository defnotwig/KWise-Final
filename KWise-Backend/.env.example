# =============================================
# K-Wise Backend Environment Configuration
# =============================================
# INSTRUCTIONS: Copy this file to .env
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)
#
# Then fill in values marked with <ASK_TEAM_LEAD>
# All other values are ready to use for local development.
# =============================================

# =============================================
# DATABASE CONFIGURATION
# =============================================
# PostgreSQL must be installed and running locally.
# See COLLABORATOR_SETUP.md for installation instructions.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=KWiseDB
DB_USER=postgres
DB_PASSWORD=humbleludwig13

# =============================================
# APPLICATION CONFIGURATION
# =============================================
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BCRYPT_SALT_ROUNDS=8
LOG_LEVEL=debug

# =============================================
# JWT CONFIGURATION
# =============================================
JWT_SECRET=kwise-super-secret-jwt-token-key-change-in-production-2025
JWT_EXPIRES_IN=7d

# =============================================
# PASSWORD RESET CONFIGURATION
# =============================================
RESET_CODE_SECRET=your-super-secret-reset-code-key-change-this-in-production
RESET_CODE_TTL_MIN=15

# =============================================
# GMAIL CONFIGURATION
# =============================================
# Ask the team lead for the Gmail credentials.
# To set up your own:
#   1. Enable 2FA on your Gmail account
#   2. Generate App Password: https://support.google.com/accounts/answer/185833
GMAIL_USER=<ASK_TEAM_LEAD>
GMAIL_APP_PASSWORD=<ASK_TEAM_LEAD>
EMAIL_FROM="K-Wise Team <noreply@kwise.com>"

# =============================================
# LOAD TESTING
# =============================================
LOAD_TEST_MODE=true

# =============================================
# AI / OLLAMA CONFIGURATION (OPTIONAL)
# =============================================
# Ollama is OPTIONAL. The system works without it.
# To enable AI features, install Ollama: https://ollama.com/download
# Then run: ollama pull deepseek-r1:1.5b
#           ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:1.5b
OLLAMA_TIMEOUT=30000
OLLAMA_MAX_RETRIES=3

AI_ENABLED=true
AI_MODEL=deepseek-r1:1.5b
AI_FALLBACK_ENABLED=true
AI_DEBUG=true

AI_CACHE_ENABLED=true
AI_CACHE_TTL=3600
AI_CACHE_TTL_HOURS=1
AI_CACHE_MAX_SIZE=1000

AI_RATE_LIMIT_ENABLED=true
AI_RATE_LIMIT_REQUESTS=100
AI_RATE_LIMIT_WINDOW=3600000

AI_HEALTH_CHECK_INTERVAL=60000

# =============================================
# REDIS CACHING (OPTIONAL)
# =============================================
# System falls back to in-memory cache if Redis is unavailable.
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_SECONDS=3600
