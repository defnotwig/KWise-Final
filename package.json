{
  "name": "kwise-launcher",
  "version": "1.0.0",
  "description": "Launcher wrapper to start K-Wise frontend and backend with one click (Windows)",
  "main": "launcher.js",
  "scripts": {
    "start-all": "node launcher.js",
    "stress:live-stack": "npm --prefix KWise-Backend run stress:live-stack",
    "build-exe": "npx pkg . --targets node18-win-x64 --output kwise-launcher.exe",
    "codex-lb:docker": "docker compose -f codex-lb/docker-compose.yml up --build",
    "codex-lb:backend": "cd codex-lb && uv run fastapi run app/main.py --reload",
    "codex-lb:frontend": "cd codex-lb/frontend && bun run dev",
    "codex-lb:test": "cd codex-lb && uv run pytest -q"
  },
  "bin": "launcher.js",
  "devDependencies": {
    "pkg": "^5.8.0"
  }
}
